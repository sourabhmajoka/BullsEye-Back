# BullsEye Environment Configuration
SECRET_KEY=change-this-in-production
JWT_SECRET_KEY=change-this-jwt-secret

# ── AI API Keys ─────────────────────────────────────────────
# Option 1: Groq (RECOMMENDED - FREE, no credit card, very fast)
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Option 2: Google Gemini (free tier)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Option 3: Anthropic Claude
CLAUDE_API_KEY=

# ── Database ────────────────────────────────────────────────
# Leave blank to use SQLite (default, no setup needed)
# DATABASE_URL=postgresql://user:password@localhost:5432/bullseye
