# BullsEye Environment Configuration
SECRET_KEY=change-this-in-production
JWT_SECRET_KEY=change-this-jwt-secret

# ── AI API Keys ─────────────────────────────────────────────
# Option 1: Groq (RECOMMENDED - FREE, no credit card, very fast)
# Get key at: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_key_here

# Option 2: Google Gemini (free tier)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Option 3: Anthropic Claude
CLAUDE_API_KEY=

# ── Database (PostgreSQL — REQUIRED) ────────────────────────
#
# DATABASE_URL is REQUIRED. SQLite is no longer supported.
# Registered users are stored permanently in PostgreSQL.
#
# ▸ Local development:
#   1. Install PostgreSQL and create a database:
#        createdb bullseye
#   2. Set the URL:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/bullseye
#
# ▸ Render (free managed PostgreSQL):
#   1. In your Render dashboard → "New PostgreSQL"
#   2. Copy the "Internal Database URL" (starts with postgres://)
#   3. Paste it here — the app automatically fixes postgres:// → postgresql://
#
# ▸ Supabase / Railway / Neon (free tiers available):
#   Same — paste the connection string provided by the platform.
